{
  "name": "converta-tudo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Conversor de arquivos online - imagens, vídeos, PDFs e muito mais!",
  "homepage": "https://convertatudo.com.br",
  "repository": {
    "type": "git",
